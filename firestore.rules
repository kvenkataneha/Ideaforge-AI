rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
         (request.auth.token.email == "eswari.d2011@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('role' in data) || (data.role in ['user', 'admin'])) &&
             (!('theme' in data) || (data.theme is string && data.theme.size() < 50)) &&
             (!('lastActive' in data) || (data.lastActive is string || data.lastActive is timestamp || data.lastActive == null));
    }

    function isValidIdea(data) {
      return data.keys().hasAll(['authorId', 'title', 'description', 'viability_score']) &&
             data.authorId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.viability_score is number &&
             (!('visibility' in data) || (data.visibility in ['private', 'public'])) &&
             (!('updatedAt' in data) || (data.updatedAt is string || data.updatedAt is timestamp || data.updatedAt == null));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['ideaId', 'userId', 'text']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'type', 'message']) &&
             data.userId == request.auth.uid &&
             data.type in ['bug', 'improvement', 'other'] &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && 
                    (request.resource.data.get('role', 'user') == 'user' || isAdmin());
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                    (request.resource.data.get('role', 'user') == resource.data.get('role', 'user') || isAdmin());
    }

    match /ideas/{ideaId} {
      allow read: if resource.data.visibility == 'public' || isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidIdea(request.resource.data);
      allow update: if (isDocOwner() && isValidIdea(request.resource.data)) || 
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']));
      allow delete: if isDocOwner() || isAdmin();
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
    }
  }
}
